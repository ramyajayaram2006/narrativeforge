# Copy to .env and fill in values
# NarrativeForge environment variables

# ── AI Provider — GROQ (recommended: fast, free) ──────────────────────────────
# Get free key at: https://console.groq.com
# When set, ALL AI features use Groq instead of Ollama (~10x faster)
GROQ_API_KEY=

# Groq model (leave as default — it's the fastest free option)
GROQ_MODEL=llama-3.1-8b-instant

# ── AI Provider — Ollama (local fallback, used when GROQ_API_KEY is empty) ────
# Default: llama3.2 — change to llama3.1, mistral, etc.
NARRATIVEFORGE_MODEL=llama3.2

# Ollama server URL
OLLAMA_HOST=http://localhost:11434

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank for local SQLite (default)
DATABASE_URL=

# Path to local SQLite file (only used when DATABASE_URL is empty)
NARRATIVEFORGE_DB=narrativeforge.db
